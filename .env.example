# Authentication
# Choose one mode:
# 1. Gemini API key
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=False

# 2. Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Historian runtime
GIT_WORKFLOW_REPO_PATH=
GWH_MODEL=gemini-3-flash-preview
GWH_MCP_SERVER_URL=
GWH_MCP_TRANSPORT=stdio
GWH_REQUEST_TIMEOUT_SECONDS=120

# API server
PORT=8080
